{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "outDir": ".build",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "functions/**/*.ts",
    "services/**/*.ts",
    "middlewares/**/*.ts",
    "models/**/*.ts"
  ]
}
